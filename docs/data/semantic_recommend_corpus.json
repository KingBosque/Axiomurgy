{
  "$comment": "Ground-truth for semantic recommendation calibration. Paths relative to Axiomurgy repo root.",
  "version": 1,
  "axiomurgy_aligned_bundles": [
    "axiomurgy_inbox_triage",
    "axiomurgy_openapi_rollback",
    "axiomurgy_research_stage",
    "axiomurgy_primer_to_axioms",
    "axiomurgy_primer_via_mcp",
