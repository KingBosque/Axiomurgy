    "axiomurgy_ouroboros_score_fixture",
    "axiomurgy_ouroboros_score_fixture_v12"
  ],
  "spells": [
    {
      "path": "examples/inbox_triage.spell.json",
      "family": "hitl_outbound",
      "expect": {
        "primary_bundle_id": "axiomurgy_inbox_triage",
        "must_include_bundle_ids": ["axiomurgy_inbox_triage"],
        "must_not_include_bundle_ids": []
      }
    },
    {
