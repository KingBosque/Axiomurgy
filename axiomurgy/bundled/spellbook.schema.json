{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/axiomurgy/spellbook.schema.json",
  "title": "Axiomurgy Spellbook",
  "type": "object",
  "required": ["name", "version", "entrypoints"],
  "properties": {
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "default_entrypoint": {"type": "string", "minLength": 1},
    "required_capabilities": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true,
      "default": []
    },
    "default_policy": {"type": "string"},
    "validators": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true,
      "default": []
    },
    "artifacts_dir": {"type": "string"},
    "entrypoints": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "oneOf": [
          {"type": "string", "minLength": 1},
          {
            "type": "object",
            "required": ["spell"],
            "properties": {
              "spell": {"type": "string", "minLength": 1},
              "policy": {"type": "string"},
              "artifacts_dir": {"type": "string"},
              "required_capabilities": {
                "type": "array",
                "items": {"type": "string"},
                "uniqueItems": true,
                "default": []
              }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
