{
  "spell": "openapi_ticket_then_fail",
  "intent": "Create a local issue through OpenAPI and then fail intentionally to exercise rollback semantics.",
  "inputs": {
    "summary": "Implement richer rollback semantics for Axiomurgy gate steps and keep provenance attached to every compensation action."
  },
  "constraints": {
    "risk": "high",
    "required_capabilities": ["transform", "verify", "write"],
    "policy": "../policies/default.policy.json"
  },
  "graph": [
    {
      "id": "draft",
      "rune": "forge.template",
      "effect": "transform",
      "args": {
        "template": "Axiomurgy follow-up\n\nSummary: {summary}\n\nAcceptance criteria:\n- rollback after post-write failure\n- compensation events in provenance\n- explicit approval gate before external writes\n",
        "bindings": {
          "summary": "$inputs.summary"
        }
      }
    },
    {
      "id": "create_ticket",
      "rune": "gate.openapi_call",
      "effect": "write",
      "args": {
        "spec": "../adapters/mock_issue_api.openapi.yaml",
        "operationId": "createTicket",
        "arguments": {
          "body": {
            "title": "Axiomurgy v0.2 rollback milestone",
            "description": "$draft",
            "labels": ["relay", "rollback", "provenance"]
          }
        }
      },
      "compensate": {
        "rune": "gate.openapi_call",
        "effect": "write",
        "args": {
          "spec": "../adapters/mock_issue_api.openapi.yaml",
          "operationId": "deleteTicket",
          "arguments": {
            "path": {
              "ticketId": "$create_ticket.body.id"
            }
          }
        }
      }
    },
    {
      "id": "force_failure",
      "rune": "seal.require",
      "effect": "verify",
      "args": {
        "value": false,
        "equals": true,
        "message": "Intentional post-write failure to test compensation."
      },
      "depends_on": ["create_ticket"]
    }
  ],
  "witness": {
    "record": true,
    "format": "prov-json",
    "path": "../artifacts/openapi_ticket_then_fail.prov.json",
    "trace_path": "../artifacts/openapi_ticket_then_fail.trace.json",
    "scxml_path": "../artifacts/openapi_ticket_then_fail.scxml"
  }
}
