{
  "spell": "primer_to_axioms_v0_6",
  "intent": "Read the bundled magic-system primers, synthesize recurring themes, and publish a relay-start artifact with deterministic validators.",
  "inputs": {
    "sources": [
      "../primers/primer_01.txt",
      "../primers/primer_02.txt",
      "../primers/primer_03.txt",
      "../primers/primer_04.txt",
      "../primers/primer_05.txt",
      "../primers/primer_06.txt",
      "../primers/primer_07.txt"
    ]
  },
  "constraints": {
    "risk": "medium",
    "required_capabilities": [
      "read",
      "transform",
      "verify",
      "write"
    ],
    "requires_approval_for": [
      "write"
    ]
  },
  "graph": [
    {
      "id": "gather",
      "rune": "mirror.read",
      "effect": "read",
      "args": {
        "input": "$inputs.sources"
      }
    },
    {
      "id": "brief",
      "rune": "forge.summarize",
      "effect": "transform",
      "args": {
        "from": "$gather",
        "title": "Axiomurgy Primer Codex"
      }
    },
    {
      "id": "validate_sections",
      "rune": "seal.assert_contains_sections",
      "effect": "verify",
      "requires": [
        "brief"
      ],
      "args": {
        "target": "$brief",
        "target_name": "direct primer brief",
        "sections": [
          "Recurring themes",
          "Source 1",
          "Source 7",
          "Axiomurgy notes"
        ]
      }
    },
    {
      "id": "validate_markers",
      "rune": "seal.assert_markers",
      "effect": "verify",
      "requires": [
        "brief"
      ],
      "args": {
        "target": "$brief",
        "target_name": "direct primer brief",
        "markers": [
          "Strong systems benefit from explicit rules",
          "A believable magical culture needs both the rules that work"
        ]
      }
    },
    {
      "id": "publish",
      "rune": "gate.file_write",
      "effect": "write",
      "requires": [
        "validate_sections",
        "validate_markers"
      ],
      "args": {
        "from": "$brief",
        "path": "../artifacts/primer_to_axioms_v0_6.md"
      }
    }
  ],
  "witness": {
    "record": true,
    "format": "prov-like"
  }
}