{
  "spell": "primer_to_axioms_v0_3",
  "intent": "Read local magic-system primers, synthesize recurring themes, and publish a relay-start artifact.",
  "inputs": {
    "sources": [
      "primers/primer1.txt",
      "primers/primer2.txt",
      "primers/primer3.txt",
      "primers/primer4.txt",
      "primers/primer5.txt",
      "primers/primer6.txt",
      "primers/primer7.txt"
    ]
  },
  "constraints": {
    "risk": "medium",
    "required_capabilities": ["read", "transform", "verify", "write"],
    "requires_approval_for": ["write"]
  },
  "graph": [
    {
      "id": "gather",
      "rune": "mirror.read",
      "effect": "read",
      "args": { "input": "$inputs.sources" }
    },
    {
      "id": "brief",
      "rune": "forge.summarize",
      "effect": "transform",
      "args": { "from": "$gather", "title": "Axiomurgy Primer Codex" }
    },
    {
      "id": "review",
      "rune": "seal.review",
      "effect": "verify",
      "args": {
        "from": "$brief",
        "must_include": ["Recurring themes", "Source 1", "Source 7", "Axiomurgy notes"]
      },
      "output_schema": {
        "type": "object",
        "required": ["approved", "missing", "artifact"],
        "properties": {
          "approved": { "type": "boolean" },
          "missing": { "type": "array" },
          "artifact": { "type": "string" }
        }
      }
    },
    {
      "id": "publish",
      "rune": "gate.file_write",
      "effect": "write",
      "args": {
        "from": "$brief",
        "path": "../artifacts/primer_to_axioms_v0_3.md"
      },
      "requires": ["review"]
    }
  ],
  "witness": { "record": true, "format": "prov-like" }
}
